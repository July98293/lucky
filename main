    // ----------------------------
    // Render table
    // ----------------------------
    const tbody = document.getElementById("rows");

    function escapeHtml(s){
      return String(s).replace(/[&<>"']/g, m => ({
        "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"
      }[m]));
    }
    function pillHTML(tag){
      return `<span class="pill mono">${escapeHtml(tag)}</span>`;
    }
    function rowHTML(item){
      return `
        <tr>
          <td><a href="#" class="mono">${escapeHtml(item.name)}</a></td>
          <td class="mono">${item.age}</td>
          <td>${escapeHtml(item.project)}</td>
          <td><div class="tagstack">${item.tags.map(pillHTML).join("")}</div></td>
          <td class="mono">${escapeHtml(item.date)}</td>
        </tr>
      `;
    }
    function applyFilters(){
      const q = search.value.trim().toLowerCase();
      const active = chips.filter(c => c.dataset.on === "true").map(c => c.dataset.tag.toLowerCase());

      const filtered = DATA.filter(item => {
        const text = (item.name + " " + item.project + " " + item.tags.join(" ")).toLowerCase();
        if (q && !text.includes(q)) return false;
        if (active.length){
          const set = new Set(item.tags.map(t => t.toLowerCase()));
          if (!active.some(t => set.has(t))) return false;
        }
        return true;
      });

      tbody.innerHTML = filtered.map(rowHTML).join("");
    }

    const search = document.getElementById("search");
    const chips = Array.from(document.getElementById("filters").querySelectorAll(".chip"));
    chips.forEach(chip => {
      chip.addEventListener("click", () => {
        chip.dataset.on = (chip.dataset.on !== "true").toString();
        applyFilters();
      });
    });
    search.addEventListener("input", applyFilters);
    applyFilters();

    // ============================================================
    // FULL-WIDTH PARTICLE WAVE STRIP
    // - particles: blue (NOT gray)
    // - wave: neon purple
    // - wave phase anchored at mouse (starts where mouse is)
    // ============================================================
    const waveDiv = document.getElementById("topwave");
    const canvas = document.getElementById("waveStrip");
    const ctx = canvas.getContext("2d");

    let W=0, H=0, dpr=1;

    function resizeCanvas(){
      const r = waveDiv.getBoundingClientRect();
      dpr = Math.max(1, window.devicePixelRatio || 1);
      W = Math.floor(r.width);
      H = Math.floor(r.height);
      canvas.width  = Math.floor(W * dpr);
      canvas.height = Math.floor(H * dpr);
      ctx.setTransform(dpr,0,0,dpr,0,0); // draw in CSS pixels
    }
    window.addEventListener("resize", resizeCanvas);
    resizeCanvas();

    const mouse = { x: W*0.25, y: H*0.55, tx: W*0.25, ty: H*0.55, active:false };

    waveDiv.addEventListener("mousemove", (e) => {
      const r = waveDiv.getBoundingClientRect();
      mouse.tx = e.clientX - r.left;
      mouse.ty = e.clientY - r.top;
      mouse.active = true;
    });
    waveDiv.addEventListener("mouseleave", () => {
      mouse.active = false;
    });

    function clamp(v,a,b){ return Math.max(a, Math.min(b,v)); }
    function lerp(a,b,t){ return a + (b-a)*t; }

    // Wave path (starts where the mouse is via (x - mouse.x))
    function waveY(x, t){
      const base = clamp(mouse.y, H*0.25, H*0.85);
      const phase = (x - mouse.x);

      const k1 = 2*Math.PI / 360;
      const k2 = 2*Math.PI / 190;

      const A1 = 30;
      const A2 = 13;

      return base
        + Math.sin(phase*k1 - t*2.2) * A1
        + Math.sin(phase*k2 - t*1.4) * A2;
    }

    // Soft tube around wave
    function falloff(dist){
      const sigma = 26;
      return Math.exp(-(dist*dist)/(2*sigma*sigma));
    }

    // Colors you asked for:
    // particles: blue-ish; wave line: neon purple
    const PARTICLE_RGB = { r: 30, g: 120, b: 255 };      // blue
    const WAVE_RGB     = { r: 190, g: 60,  b: 255 };     // neon-ish purple

    let t0 = performance.now();

    function draw(now){
      const t = (now - t0) / 1000;

      // smooth tracking (wave starts at mouse)
      const follow = mouse.active ? 0.18 : 0.06;
      mouse.x = lerp(mouse.x, mouse.tx || mouse.x, follow);
      mouse.y = lerp(mouse.y, mouse.ty || mouse.y, follow);

      ctx.clearRect(0,0,W,H);

      // ultra-light paper wash
      ctx.fillStyle = "rgba(0,0,0,0.01)";
      ctx.fillRect(0,0,W,H);

      // particle grid (density controls)
      const cols = Math.max(120, Math.floor(W / 6));  // scale with width
      const rows = Math.max(22,  Math.floor(H / 9));
      const padX = 14, padY = 14;

      const gx0 = padX, gx1 = W - padX;
      const gy0 = padY, gy1 = H - padY;
      const dx = (gx1 - gx0) / (cols - 1);
      const dy = (gy1 - gy0) / (rows - 1);

      // draw particles; increase alpha near the wave
      for(let j=0;j<rows;j++){
        const py = gy0 + j*dy;
        for(let i=0;i<cols;i++){
          const px = gx0 + i*dx;

          const wy = waveY(px, t);
          const dist = Math.abs(py - wy);
          const f = falloff(dist); // 0..1

          if (f < 0.03) continue;

          // subtle shimmer
          const shimmer = 0.5 + 0.5*Math.sin((px*0.03 + py*0.02) + t*2.4);
          const alpha = 0.02 + 0.22 * f * (0.6 + 0.4*shimmer);
          const r = 0.7 + 2.4 * f;

          const jitter = (Math.sin((px+py)*0.02 + t*3.0) * 1.2) * f;

          ctx.fillStyle = `rgba(${PARTICLE_RGB.r},${PARTICLE_RGB.g},${PARTICLE_RGB.b},${alpha})`;
          ctx.beginPath();
          ctx.arc(px + jitter, py, r, 0, Math.PI*2);
          ctx.fill();
        }
      }

      // neon purple wave line on top
      // glow pass
      ctx.save();
      ctx.lineWidth = 6;
      ctx.lineCap = "round";
      ctx.lineJoin = "round";
      ctx.shadowBlur = 18;
      ctx.shadowColor = `rgba(${WAVE_RGB.r},${WAVE_RGB.g},${WAVE_RGB.b},0.65)`;
      ctx.strokeStyle = `rgba(${WAVE_RGB.r},${WAVE_RGB.g},${WAVE_RGB.b},0.65)`;
      ctx.beginPath();
      for(let x=0;x<=W;x+=6){
        const y = waveY(x, t);
        if (x===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
      }
      ctx.stroke();
      ctx.restore();

      // core line
      ctx.lineWidth = 2.2;
      ctx.strokeStyle = `rgba(${WAVE_RGB.r},${WAVE_RGB.g},${WAVE_RGB.b},0.95)`;
      ctx.beginPath();
      for(let x=0;x<=W;x+=6){
        const y = waveY(x, t);
        if (x===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
      }
      ctx.stroke();

      // soft vignette
      const g = ctx.createRadialGradient(W*0.55, H*0.55, 20, W*0.55, H*0.55, Math.max(W,H)*0.75);
      g.addColorStop(0, "rgba(255,255,255,0)");
      g.addColorStop(1, "rgba(255,255,255,0.7)");
      ctx.fillStyle = g;
      ctx.fillRect(0,0,W,H);

      requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);
  </script>
</body>
</html>
